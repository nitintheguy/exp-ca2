<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nivaran | My Portal</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-[#f8fafc] min-h-screen font-sans antialiased">

    <%- include('partials/nav') %>

    <main style="max-width: 1100px; margin: 0 auto; padding: 8rem 1.5rem 4rem;">

        <!-- HEADER ROW -->
        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 3rem;">
            <div>
                <span class="inline-block px-4 py-1.5 text-[10px] font-bold tracking-[0.2em] uppercase text-gov-green bg-gov-green/10 rounded-full border border-gov-green/20" style="margin-bottom: 1rem;">
                    Citizen Dashboard
                </span>
                <h1 class="font-black tracking-tighter text-slate-900" style="font-size: 2.5rem; line-height: 1.1;">
                    Welcome, <%= user.firstName %>.
                </h1>
                <p class="text-slate-500" style="margin-top: 0.5rem; font-size: 0.9rem;">
                    Manage your grievances and track their resolution status.
                </p>
            </div>
            <a href="/grievance/new" style="display: inline-flex; align-items: center; gap: 8px; padding: 0.875rem 1.75rem; background: #003366; color: white; border-radius: 1rem; font-weight: 700; font-size: 0.8rem; text-decoration: none; letter-spacing: 0.05em; white-space: nowrap; flex-shrink: 0;">
                + File New Grievance
            </a>
        </div>

        <!-- STAT CARDS -->
        <div style="display: flex; gap: 1rem; margin-bottom: 3rem;">
            <div style="flex: 1; background: white; border-radius: 1rem; border: 1px solid #e2e8f0; padding: 1.5rem;">
                <p class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em; margin-bottom: 0.5rem;">Total Filed</p>
                <p class="font-black tracking-tighter text-slate-900" style="font-size: 2rem;"><%= grievances.length %></p>
            </div>
            <div style="flex: 1; background: white; border-radius: 1rem; border: 1px solid #e2e8f0; padding: 1.5rem;">
                <p class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em; margin-bottom: 0.5rem;">Pending</p>
                <p class="font-black tracking-tighter text-gov-saffron" style="font-size: 2rem;"><%= grievances.filter(g => g.status === 'pending').length %></p>
            </div>
            <div style="flex: 1; background: white; border-radius: 1rem; border: 1px solid #e2e8f0; padding: 1.5rem;">
                <p class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em; margin-bottom: 0.5rem;">In Progress</p>
                <p class="font-black tracking-tighter text-gov-blue" style="font-size: 2rem;"><%= grievances.filter(g => g.status === 'in-progress').length %></p>
            </div>
            <div style="flex: 1; background: white; border-radius: 1rem; border: 1px solid #e2e8f0; padding: 1.5rem;">
                <p class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em; margin-bottom: 0.5rem;">Resolved</p>
                <p class="font-black tracking-tighter text-gov-green" style="font-size: 2rem;"><%= grievances.filter(g => g.status === 'resolved').length %></p>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">

            <!-- GRIEVANCES LIST -->
            <div style="flex: 2;">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
                    <h2 class="font-black tracking-tighter text-slate-900" style="font-size: 1.1rem;">My Grievances</h2>
                    <span class="text-[10px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em;"><%= grievances.length %> total</span>
                </div>

                <% if (grievances.length === 0) { %>
                    <div style="background: white; border-radius: 1rem; border: 1px solid #e2e8f0; padding: 3rem; text-align: center;">
                        <p style="font-size: 2rem; margin-bottom: 0.75rem;">📋</p>
                        <p class="font-black text-slate-900" style="margin-bottom: 0.4rem;">No grievances filed yet</p>
                        <p class="text-slate-400" style="font-size: 0.85rem; margin-bottom: 1.5rem;">File your first grievance to get started.</p>
                        <a href="/grievance/new" style="display: inline-block; padding: 0.75rem 1.5rem; background: #003366; color: white; border-radius: 0.75rem; font-weight: 700; font-size: 0.8rem; text-decoration: none;">
                            File a Grievance
                        </a>
                    </div>
                <% } else { %>
                    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                        <% grievances.slice().reverse().forEach(g => { %>
                            <a href="/grievance/<%= g._id %>" style="display: block; background: white; border-radius: 1rem; border: 1px solid #e2e8f0; padding: 1.25rem 1.5rem; text-decoration: none; transition: box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,51,102,0.08)'" onmouseout="this.style.boxShadow='none'">
                                <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;">
                                    <div style="flex: 1;">
                                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.4rem;">
                                            <p class="font-black text-slate-900" style="font-size: 0.95rem;"><%= g.title %></p>
                                        </div>
                                        <p class="text-slate-500" style="font-size: 0.8rem; margin-bottom: 0.75rem; line-height: 1.5;"><%= g.description.substring(0, 100) %><%= g.description.length > 100 ? '...' : '' %></p>
                                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                            <span style="padding: 3px 10px; background: #f1f5f9; border-radius: 999px; font-size: 10px; font-weight: 700; color: #64748b; letter-spacing: 0.1em; text-transform: uppercase;"><%= g.category %></span>
                                            <span style="padding: 3px 10px; background: #f1f5f9; border-radius: 999px; font-size: 10px; font-weight: 700; color: #64748b; letter-spacing: 0.1em; text-transform: uppercase;"><%= g.department %></span>
                                        </div>
                                    </div>
                                    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; flex-shrink: 0;">
                                        <%
                                            const statusColors = {
                                                'pending':     { bg: '#fff7ed', color: '#c2410c', border: '#fed7aa' },
                                                'in-progress': { bg: '#eff6ff', color: '#1d4ed8', border: '#bfdbfe' },
                                                'resolved':    { bg: '#f0fdf4', color: '#15803d', border: '#bbf7d0' },
                                                'closed':      { bg: '#f8fafc', color: '#64748b', border: '#e2e8f0' }
                                            };
                                            const sc = statusColors[g.status] || statusColors['pending'];
                                        %>
                                        <span style="padding: 4px 12px; background: <%= sc.bg %>; color: <%= sc.color %>; border: 1px solid <%= sc.border %>; border-radius: 999px; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap;">
                                            <%= g.status %>
                                        </span>
                                        <span class="text-slate-400" style="font-size: 10px; font-weight: 600;">
                                            <%= new Date(g.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                        </span>
                                    </div>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- PROFILE CARD -->
            <div style="flex: 1; position: sticky; top: 8rem;">
                <div style="background: white; border-radius: 1rem; border: 1px solid #e2e8f0; overflow: hidden;">

                    <!-- Card header -->
                    <div style="background: #003366; padding: 1.75rem; text-align: center;">
                        <div style="width: 60px; height: 60px; border-radius: 50%; background: white; color: #003366; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 900; margin: 0 auto 0.75rem; letter-spacing: 0.05em;">
                            <%= user.firstName[0].toUpperCase() %><%= user.lastName[0].toUpperCase() %>
                        </div>
                        <p class="font-black text-white" style="font-size: 1rem; letter-spacing: -0.02em;"><%= user.firstName %> <%= user.lastName %></p>
                        <span style="display: inline-block; margin-top: 0.4rem; padding: 3px 12px; background: rgba(255,255,255,0.15); border-radius: 999px; font-size: 9px; font-weight: 700; color: white; letter-spacing: 0.15em; text-transform: uppercase;">
                            <%= user.role %>
                        </span>
                    </div>

                    <!-- Card body -->
                    <div style="padding: 1.25rem;">
                        <div style="display: flex; flex-direction: column; gap: 0.875rem;">
                            <div style="display: flex; flex-direction: column; gap: 2px;">
                                <span class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em;">Email</span>
                                <span class="text-slate-700 font-bold" style="font-size: 0.8rem; word-break: break-all;"><%= user.email %></span>
                            </div>
                            <div style="border-top: 1px solid #f1f5f9; padding-top: 0.875rem; display: flex; flex-direction: column; gap: 2px;">
                                <span class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em;">Mobile</span>
                                <span class="text-slate-700 font-bold" style="font-size: 0.8rem;"><%= user.mobile %></span>
                            </div>
                            <div style="border-top: 1px solid #f1f5f9; padding-top: 0.875rem; display: flex; flex-direction: column; gap: 2px;">
                                <span class="text-[9px] font-bold uppercase text-slate-400" style="letter-spacing: 0.2em;">Member Since</span>
                                <span class="text-slate-700 font-bold" style="font-size: 0.8rem;">
                                    <%= new Date(user.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                </span>
                            </div>
                        </div>

                        <a href="/logout" style="display: block; margin-top: 1.25rem; padding: 0.75rem; text-align: center; border: 1px solid #e2e8f0; border-radius: 0.75rem; font-size: 11px; font-weight: 700; color: #94a3b8; text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;">
                            Sign Out
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </main>
</body>
</html>