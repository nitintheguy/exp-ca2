<header class="fixed top-6 inset-x-0 z-50 flex justify-center px-6">
  <nav class="flex items-center justify-between w-full max-w-5xl bg-white/70 backdrop-blur-xl border border-white/40 px-8 py-3 rounded-[2rem] shadow-[0_20px_50px_rgba(0,51,102,0.1)] transition-all duration-500 hover:shadow-[0_20px_50px_rgba(0,51,102,0.2)] hover:bg-white/80">
    
    <a href="/" class="flex items-center gap-3 group">
      <div class="flex flex-col">
        <span class="text-xl font-black text-slate-800 leading-none tracking-tight">Nivaran</span>
        <span class="text-[9px] uppercase tracking-[0.25em] text-gov-green font-bold mt-1">Digital Portal</span>
      </div>
    </a>

    <div class="hidden md:flex items-center gap-10 text-[13px] font-bold uppercase tracking-wider text-slate-500">
      <a href="/" class="relative group py-1 <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'text-gov-blue' : '' %>">
        Home
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gov-blue transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300 <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'scale-x-100' : '' %>"></span>
      </a>
      <a href="/about" class="relative group py-1 hover:text-gov-blue transition-colors">
        About
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gov-blue transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>
      </a>
      <a href="/track-status" class="relative group py-1 hover:text-gov-blue transition-colors">
        Track Status
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gov-blue transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>
      </a>
    </div>
<div class="flex items-center gap-6">
  <% if (locals.user) { %>

    <a href="/profile" class="group" style="display:flex; align-items:center; gap:10px; padding:6px 16px 6px 6px; border-radius:999px; border:1px solid #e2e8f0; background:white; text-decoration:none; transition: all 0.3s ease;">
      <span style="width:32px; height:32px; border-radius:50%; background:#003366; color:white; display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:800; flex-shrink:0; letter-spacing:0.05em;">
        <%= user.firstName[0].toUpperCase() %><%= user.lastName[0].toUpperCase() %>
      </span>
      <span style="font-size:12px; font-weight:700; color:#1e293b; white-space:nowrap;"><%= user.firstName %></span>
    </a>

    <a href="/logout" class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 hover:text-red-500 transition-colors">
      Logout
    </a>

  <% } else { %>

    <a href="/login" class="text-sm font-bold text-slate-700 hover:text-gov-blue transition-colors">Login</a>
    <a href="/signup" class="relative inline-flex items-center justify-center px-7 py-3 overflow-hidden font-bold text-white transition-all duration-300 bg-gov-blue rounded-2xl group hover:bg-blue-900 shadow-xl shadow-blue-900/20 active:scale-95">
      <span class="absolute inset-0 w-full h-full bg-white/10 group-hover:translate-x-full transition-transform duration-500 -translate-x-full"></span>
      <span class="relative text-xs uppercase tracking-widest">Get Started</span>
    </a>

  <% } %>
</div>
    
  </nav>
</header>